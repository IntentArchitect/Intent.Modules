    <script name="HTTP Route Update Scripts" id="abf4c85d-7709-443a-8817-ffa6cb9dd99f">
      <script>function updateVersionParameter(element) {
    const apiVersionStereotypeId = "20855f03-c663-4ec6-b106-de06be98f1fe";
    const httpSettingsStereotypeId = "b4581ed2-42ec-4ae2-83dd-dcdd5f0837b6";

    let route = element.getStereotype(httpSettingsStereotypeId)?.getProperty("Route")?.getValue();

    if (!element.hasStereotype(apiVersionStereotypeId) &amp;&amp; route?.indexOf("{version}") &gt;= 0) {
        // Api version Stereotype removed
        route = route.replace("{version}/", "");
        element.getStereotype(httpSettingsStereotypeId).getProperty("Route").setValue(route);
        return;
    }

    if (element.hasStereotype(apiVersionStereotypeId) &amp;&amp; route?.indexOf("{version}") &lt; 0) {
        // Api version Stereotype added
        let defaultRoutePrefix = getDefaultRoutePrefix(false);
        let startIndex = route.indexOf(defaultRoutePrefix);
        if (startIndex == 0) {
            route = `${defaultRoutePrefix}/{version}/${(route.substring(defaultRoutePrefix.length + 1))}`;
        } else {
            route = `{version}/${(route)}`;
        }
        element.getStereotype(httpSettingsStereotypeId).getProperty("Route").setValue(route);
        return;
    }
}

function getRouteRemovalExclusions(element) {
    let routeExclusions = [];

    if(element.hasStereotype("20855f03-c663-4ec6-b106-de06be98f1fe")) {
        // version is always excluded
        routeExclusions.push("version");
    }

    // get the multi-tenancy route parameter configured
    let multiTenancyRouteStrategy = application.getSettings("41ae5a02-3eb2-42a6-ade2-322b3c1f1115")?.getField("e15fe0fb-be28-4cc5-8b85-37a07b7ca160")?.value;
    let multiTenancyRoute = application.getSettings("41ae5a02-3eb2-42a6-ade2-322b3c1f1115")?.getField("c8ff4af6-68b6-4e31-a291-43ada6a0008a")?.value;

    if(multiTenancyRouteStrategy &amp;&amp; multiTenancyRouteStrategy != "" &amp;&amp; multiTenancyRouteStrategy === "route" 
        &amp;&amp; multiTenancyRoute &amp;&amp; multiTenancyRoute != "") {
        routeExclusions.push(multiTenancyRoute);
    }

    return routeExclusions;
}

function getDefaultRoutePrefix(includeLastPathSeparator) {
    const apiSettingsId = "4bd0b4e9-7b53-42a9-bb4a-277abb92a0eb";

    let route = "api/";

    let defaultApiRouteField = application.getSettings(apiSettingsId)?.getField("Default API Route Prefix");
    if (defaultApiRouteField) {
        route = defaultApiRouteField.value ?? "";
    }

    if (includeLastPathSeparator &amp;&amp; !route.endsWith("/")) {
        route += "/";
    } else if (!includeLastPathSeparator &amp;&amp; route.endsWith("/")) {
        route = removeSuffix(route, "/");
    }

    return route;
}

function updateRouteParameters(element) {
    const httpSettingsStereotypeId = "b4581ed2-42ec-4ae2-83dd-dcdd5f0837b6";
    const parameterSettingsStereotypeId = "d01df110-1208-4af8-a913-92a49d219552";
    let route = element.getStereotype(httpSettingsStereotypeId)?.getProperty("Route")?.getValue()?.toString() ?? null;
    if (route == null) {
        return;
    }

    // UPDATE RENAMED ROUTE PARAMETERS:
    let changedRouteParams = element.getChildren(["DTO-Field", "Parameter"])
        .filter(x =&gt; x.getPreviousName &amp;&amp; x.getName() != x.getPreviousName())
        .filter(x =&gt; route.indexOf(`{${toCamelCase(x.getPreviousName())}}` != -1
            || route.indexOf(`{${toCamelCase(x.getPreviousName())}:` != -1)))
        // handle the case where you ctrl + enter / copy + paste a new element and takes over the route paramenter in the route:
        .filter(x =&gt; !element.getChildren(["DTO-Field", "Parameter"]).some(c =&gt; c.id != x.id &amp;&amp; c.getName() == x.getPreviousName()));

    changedRouteParams.forEach(x =&gt; {
        route = route.replace(`{${toCamelCase(x.getPreviousName())}}`, `{${toCamelCase(x.getName())}}`);
        route = route.replace(`{${toCamelCase(x.getPreviousName())}:`, `{${toCamelCase(x.getName())}:`);
    });

    // ADD MISSING ROUTE PARAMETERS:
    const missingFromRoute = element.getChildren(["DTO-Field", "Parameter"])
        .filter(x =&gt; x.getStereotype(parameterSettingsStereotypeId)?.getProperty("Source")?.getValue() == "From Route")
        .filter(x =&gt; route.indexOf(`{${toCamelCase(x.getName())}}`) == -1
            &amp;&amp; route.indexOf(`{${toCamelCase(x.getName())}:`) == -1)

    missingFromRoute.forEach(x =&gt; {
        route = removeSuffix(route, "/") + `/{${toCamelCase(x.getName())}}`
    });

    let routeExclusions = getRouteRemovalExclusions(element);

    // REMOVE UNBINDABLE ROUTE PARAMETERS;
    const parametersInRoute = route.split("{").filter(x =&gt; x.indexOf("}") != -1).map(x =&gt; x.split("}")[0]);
    parametersInRoute.forEach(param =&gt; {
        const mustRemove = element.getChildren(["DTO-Field", "Parameter"])
            .every(x =&gt;
                toCamelCase(x.getName()) != param.split(":")[0] ||
                (
                    x.hasStereotype(parameterSettingsStereotypeId) &amp;&amp;
                    ["From Route", "Default"].every(s =&gt; x.getStereotype(parameterSettingsStereotypeId).getProperty("Source").getValue() != s)
                )
            ) &amp;&amp; routeExclusions.indexOf(param) &lt; 0;
        if (mustRemove) {
            route = route.replace(`/{${param}}`, ``);
        }
    });

    element.getStereotype(httpSettingsStereotypeId).getProperty("Route").setValue(route);
}
</script>
    </script>
  </scripts>
</settings>