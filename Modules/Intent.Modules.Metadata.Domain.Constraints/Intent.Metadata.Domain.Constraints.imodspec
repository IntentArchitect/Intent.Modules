<?xml version="1.0" encoding="utf-8"?>
<package>
  <id>Intent.Metadata.Domain.Constraints</id>
  <version>1.0.2</version>
  <supportedClientVersions>[4.4.0-a,6.0.0-a)</supportedClientVersions>
  <summary>Centralize application validation by applying constraints on your Domain Entities.</summary>
  <description>Centralize application validation by applying constraints on your Domain Entities.</description>
  <authors>Intent Architect</authors>
  <iconUrl>data:image/svg+xml;base64,</iconUrl>
  <templates></templates>
  <decorators></decorators>
  <factoryExtensions></factoryExtensions>
  <moduleSettings></moduleSettings>
  <dependencies>
    <dependency id="Intent.Common" version="3.7.2" />
    <dependency id="Intent.Common.Types" version="3.4.0" />
    <dependency id="Intent.Modelers.Domain" version="3.12.14" />
  </dependencies>
  <interoperability>
    <detect id="Intent.Application.FluentValidation.Dtos">
      <install>
        <package id="Intent.Application.FluentValidation.Dtos" version="3.12.8" />
      </install>
    </detect>
    <detect id="Intent.Application.MediatR.FluentValidation">
      <install>
        <package id="Intent.Application.MediatR.FluentValidation" version="4.10.1" />
      </install>
    </detect>
    <detect id="Intent.EntityFrameworkCore">
      <install>
        <package id="Intent.EntityFrameworkCore" version="5.0.41" />
      </install>
    </detect>
  </interoperability>
  <files>
    <file src="$outDir$/$id$.dll" />
    <file src="$outDir$/$id$.pdb" />
  </files>
  <tags>Metadata domain constraint validation central</tags>
  <moduleSettingsExtensions />
  <metadata>
    <install target="Domain" src="Intent.Metadata/Module Builder/Intent.Metadata.Domain.Constraints/Intent.Metadata.Domain.Constraints.pkg.config" externalReference="f852e12f-1a19-4c8d-8192-8393c6ce59da" />
