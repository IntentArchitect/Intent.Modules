<?xml version="1.0" encoding="utf-8"?>
<settings version="3.1.1">
  <id>2012ebcc-fcd5-4722-96eb-78a94395779b</id>
  <name>Domain Constraints Domain Settings</name>
  <designerReferences />
  <packageSettings />
  <packageExtensions />
  <elementSettings />
  <elementExtensions>
    <elementExtension type="Attribute" typeId="0090fb93-483e-41af-a11d-5ad2dc796adf">
      <contextMenuOptions>
        <runScript group="3" type="run-script">
          <text>Add Domain Constraint</text>
          <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
          <subMenuOptions>
            <runScript type="run-script">
              <text>Add Required</text>
              <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
              <script>const requiredStereotypeId = "14680476-e24a-490f-ba44-75eb8dc6fb46";
if (!element.hasStereotype(requiredStereotypeId)) {
    element.addStereotype(requiredStereotypeId);
}</script>
            </runScript>
            <runScript type="run-script">
              <text>Add Text Limits</text>
              <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
              <isOptionVisibleFunction>return element.typeReference.getType()?.getName() === "string";</isOptionVisibleFunction>
              <script>const textLimitsStereotypeId = "13649b19-4dfe-43ec-967f-0b85a5801dd6";
if (!element.hasStereotype(textLimitsStereotypeId)) {
    element.addStereotype(textLimitsStereotypeId);
}</script>
            </runScript>
            <runScript type="run-script">
              <text>Add Numeric Limits</text>
              <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
              <isOptionVisibleFunction>const targetElements = new Set(['int', 'long', 'short', 'decimal', 'float', 'long']);

return targetElements.has(element.typeReference.getType()?.getName());</isOptionVisibleFunction>
              <script>const numericLimitsStereotypeId = "cb14e47d-672c-4244-8950-7c4ebf8cf8ed";
if (!element.hasStereotype(numericLimitsStereotypeId)) {
    element.addStereotype(numericLimitsStereotypeId);
}</script>
            </runScript>
            <runScript type="run-script">
              <text>Add Collection Limits</text>
              <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
              <isOptionVisibleFunction>return element.typeReference.getIsCollection();</isOptionVisibleFunction>
              <script>const collectionLimitsStereotypeId = "06daef0d-5be0-43e0-9cc6-2bb8ea35dc86";
if (!element.hasStereotype(collectionLimitsStereotypeId)) {
    element.addStereotype(collectionLimitsStereotypeId);
}</script>
            </runScript>
            <runScript type="run-script">
              <text>Add Email</text>
              <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
              <isOptionVisibleFunction>return element.typeReference.getType()?.getName() === "string";</isOptionVisibleFunction>
              <script>const emailStereotypeId = "9fb8d1b1-39b3-4f16-88e0-34d24a4e9bf6";
if (!element.hasStereotype(emailStereotypeId)) {
    element.addStereotype(emailStereotypeId);
}</script>
            </runScript>
            <runScript type="run-script">
              <text>Add Regular Expression</text>
              <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
              <isOptionVisibleFunction>return element.typeReference.getType()?.getName() === "string";</isOptionVisibleFunction>
              <script>const regularExpressionStereotypeId = "3dd144bc-374b-4acd-841a-7323210df66d";
if (!element.hasStereotype(regularExpressionStereotypeId)) {
    element.addStereotype(regularExpressionStereotypeId);
}</script>
            </runScript>
            <runScript type="run-script">
              <text>Add Url</text>
              <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
              <isOptionVisibleFunction>return element.typeReference.getType()?.getName() === "string";</isOptionVisibleFunction>
              <script>const urlStereotypeId = "1b2dc31a-599f-449b-9646-1a5313d23f91";
if (!element.hasStereotype(urlStereotypeId)) {
    element.addStereotype(urlStereotypeId);
}</script>
            </runScript>
            <runScript type="run-script">
              <text>Add Base 64</text>
              <icon type="UrlImagePath" source="data:image/svg+xml;base64," />
              <isOptionVisibleFunction>return element.typeReference.getType()?.getName() === "string";</isOptionVisibleFunction>
              <script>const base64StereotypeId = "02308621-429c-4af4-9428-2ebb272e53fa";
if (!element.hasStereotype(base64StereotypeId)) {
    element.addStereotype(base64StereotypeId);
}</script>
            </runScript>
          </subMenuOptions>
          <script>return;</script>
        </runScript>
      </contextMenuOptions>
      <typeOrder />
      <mappingSettings />
    </elementExtension>
  </elementExtensions>
  <associationSettings />
  <associationExtensions />
  <mappingSettings />
  <mappableElementPackages />
  <mappableElementPackageExtensions />
